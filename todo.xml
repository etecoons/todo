<?xml version="1.0"?>
<Container version="2">
  <Name>todo</Name>
  <Repository>ghcr.io/studio2201/todo:latest</Repository>
  <Registry>https://ghcr.io/studio2201/todo</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/studio2201/todo/issues</Support>
  <Project>https://github.com/studio2201/todo</Project>
  <Overview>Fast, secure self-hosted task and project management kanban application built in Rust.</Overview>
  <Category>Productivity:Other Network:Web</Category>
  <WebUI>http://[IP]:[PORT:4403]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/studio2201/unraid-templates/master/templates/todo.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/studio2201/unraid-templates/master/icons/todo.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>Fast, secure self-hosted task and project management kanban application built in Rust.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>4403</HostPort>
        <ContainerPort>4403</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/todo</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>4403</Value>
      <Name>PORT</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/config</Value>
      <Name>DATA_DIR</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="Web UI Port" Target="4403" Default="4403" Mode="tcp" Description="HTTP Web Interface Port" Type="Port" Display="always" Required="true" Mask="false">4403</Config>
  <Config Name="App Storage Directory" Target="/config" Default="/mnt/user/appdata/todo" Mode="rw" Description="Persistent data and configuration directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/todo</Config>
</Container>
