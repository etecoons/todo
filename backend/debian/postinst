#!/bin/sh
# postinst script for todo
set -e

case "$1" in
    configure)
        # Create system user (nobody:users with UID/GID 99/100 to match Unraid layout)
        if ! getent group todo >/dev/null 2>&1; then
            addgroup --system --gid 100 todo 2>/dev/null || true
        fi
        if ! getent passwd todo >/dev/null 2>&1; then
            adduser --system --uid 99 --ingroup todo \
                --home /var/lib/todo \
                --no-create-home \
                --shell /usr/sbin/nologin \
                --gecos "Todo task tracker service account" \
                todo 2>/dev/null || true
        fi

        # Create data directory
        mkdir -p /var/lib/todo
        chown todo:todo /var/lib/todo
        chmod 755 /var/lib/todo

        # Create default config file if missing
        if [ ! -f /etc/default/todo ]; then
            cat > /etc/default/todo << 'CFGEOF'
# Default configuration for Todo task tracker
# Override any value by uncommenting and editing.
PORT=4403
SITE_TITLE=Todo task tracker
TZ=UTC
CFGEOF
            chmod 644 /etc/default/todo
        fi

        echo "==============================================="
        echo "  Todo task tracker installed successfully"
        echo "  Config:  /etc/default/todo"
        echo "  Data:    /var/lib/todo"
        echo "  Binary:  /usr/bin/todo"
        echo ""
        echo "  Start manually: todo"
        echo "==============================================="
        ;;
esac

#DEBHELPER#
exit 0
